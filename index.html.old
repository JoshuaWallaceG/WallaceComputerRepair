<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wallace Computer Repair</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body class="home">
  <div class="page">
    <div class="shell">
      <header class="site-header">
        <a class="logo-lockup" href="/" aria-label="Wallace Computer Repair home">
          <img src="assets/logos/BannerLogoTransparent.png" alt="Wallace Computer Repair" class="logo-image" />
        </a>

        <nav class="main-nav" aria-label="Main navigation">
          <a class="nav-link" href="">Home</a>
          <a class="nav-link" href="repair/">Computer Repair</a>
          <a class="nav-link" href="projects/">Projects</a>
          <!-- <a class="nav-link" href="/about/">About</a> -->
          <!-- <a class="button call-pill" href="tel:5097619362">Call/Text: 509-761-9362</a> -->
        </nav>
      </header>

      <main>
        <section class="hero hero-centered" aria-labelledby="main-heading">
          <h1 id="main-heading">Hi, I’m Josh. What brings you here?</h1>
          <!-- <p>Choose the path that fits what you need: local computer help in the Tri-Cities, or a look at the engineering and software projects I’m building.</p> -->
        </section>

        <section class="choices" aria-label="Choose a section">
          <a class="choice-card repair-card" href="/repair/" aria-label="Go to Computer Repair services">
            <div class="choice-inner">
              <div class="illustration" aria-hidden="true">
                <div class="soft-blob"></div>
                <div class="monitor">
                  <div class="mini-magnifying-glass"></div>
                </div>
                <div class="wrench"></div>
                <div class="sparkle one">✦</div>
                <div class="sparkle two">✦</div>
              </div>

              <h2>Computer Repair</h2>
              <p>In-home and on-site tech help in the Tri-Cities for slow computers, virus removal, backups, and everyday tech problems.</p>

              <div class="button-row">
                <span class="button primary" role="button" aria-hidden="true">Get Computer Help</span>
              </div>
            </div>
          </a>

          <a class="choice-card projects-card" href="/projects/" aria-label="Go to Projects portfolio">
            <div class="choice-inner">
              <div class="illustration" aria-hidden="true">
                <div class="soft-blob"></div>
                <div class="code-window"></div>
                <div class="laptop">&lt;/&gt;</div>
                <!-- <div class="gear"></div> -->
              </div>

              <h2>Projects</h2>
              <p>A small portfolio of my engineering projects, GitHub repos, programs, and other things I've built while learning.</p>

              <div class="button-row">
                <span class="button secondary" role="button" aria-hidden="true">View Projects</span>
              </div>
            </div>
          </a>
        </section>
      </main>

      <footer class="site-footer">
        Wallace Computer Repair · Tri-Cities, WA · <a href="tel:5097619362">509-761-9362</a>
      </footer>
    </div>
  </div>
</body>
</html>
